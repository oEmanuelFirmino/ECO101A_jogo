2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_4017)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_4013)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_4006)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div><!----><!----></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c3358885363="" class="response-container-content ng-tns-c3358885363-280 has-thoughts"><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c927349975="" class="response-content ng-tns-c3358885363-280"><!----><model-thoughts _ngcontent-ng-c927349975="" _nghost-ng-c1786796508="" class="ng-tns-c1786796508-282 ng-star-inserted" style="height: auto;"><div _ngcontent-ng-c1786796508="" class="model-thoughts ng-tns-c1786796508-282"><div _ngcontent-ng-c1786796508="" class="thoughts-header ng-tns-c1786796508-282"><button _ngcontent-ng-c1786796508="" mat-button="" data-test-id="thoughts-header-button" class="mdc-button mat-mdc-button-base thoughts-header-button ng-tns-c1786796508-282 mat-mdc-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="247951;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-content"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-label ng-tns-c1786796508-282"><span _ngcontent-ng-c1786796508="" class="ng-tns-c1786796508-282">Mostrar raciocínio</span></div><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-icons ng-tns-c1786796508-282"><!----><mat-icon _ngcontent-ng-c1786796508="" role="img" fonticon="expand_more" class="mat-icon notranslate thoughts-header-button-icon ng-tns-c1786796508-282 google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="expand_more"></mat-icon><!----></div></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button></div><!----></div></model-thoughts><!----><!----><!----><!----><message-content _ngcontent-ng-c927349975="" class="model-response-text ng-star-inserted has-thoughts" _nghost-ng-c3841436833="" id="message-content-id-r_9e40fc8c83184a17" style="height: auto;"><div _ngcontent-ng-c3841436833="" class="markdown markdown-main-panel stronger enable-updated-hr-color" id="model-response-message-contentr_9e40fc8c83184a17" dir="ltr" style="--animation-duration: 400ms; --fade-animation-function: linear;"><p data-sourcepos="1:1-1:132">Com certeza! Adicionar uma narrativa entre as fases é uma excelente forma de dar mais profundidade e contexto à jornada do jogador.</p><p data-sourcepos="3:1-3:47">Vamos implementar essa história em duas partes:</p><ol data-sourcepos="5:1-7:0">
<li data-sourcepos="5:1-5:64">Uma tela de introdução que aparece logo após o menu inicial.</li>
<li data-sourcepos="6:1-7:0">Telas de interlúdio que surgem entre a conclusão de uma fase e o início da próxima.</li>
</ol><p data-sourcepos="8:1-8:100">Usaremos a "Tela de Mensagem" (<code>message-screen</code>) que já existe no seu jogo para exibir esses textos.</p><h3 data-sourcepos="10:1-10:51">Passo 1: Adicionar um Botão "Continuar" ao HTML</h3><p data-sourcepos="12:1-12:110">Primeiro, precisamos de um botão "Continuar" na tela de mensagem para que o jogador possa avançar na história.</p><p data-sourcepos="14:1-14:107"><strong>No arquivo <code>ECOM00_jogo/index.html</code>, adicione o botão <code>continue-button</code> dentro da div <code>message-screen</code>:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-288 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-288 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-288 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-288">HTML</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-288 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-288 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-288"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-288"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-288"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-288" data-sourcepos="16:1-23:9"><span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"message-screen"</span> <span class="hljs-attr">class</span>=<span class="hljs-string">"hidden"</span>&gt;</span>
  <span class="hljs-tag">&lt;<span class="hljs-name">h1</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"message-title"</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">h1</span>&gt;</span>
  <span class="hljs-tag">&lt;<span class="hljs-name">p</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"message-subtitle"</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
  <span class="hljs-tag">&lt;<span class="hljs-name">button</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"restart-button"</span>&gt;</span>Reiniciar<span class="hljs-tag">&lt;/<span class="hljs-name">button</span>&gt;</span>
  <span class="hljs-tag">&lt;<span class="hljs-name">button</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"continue-button"</span> <span class="hljs-attr">class</span>=<span class="hljs-string">"hidden"</span>&gt;</span>Continuar<span class="hljs-tag">&lt;/<span class="hljs-name">button</span>&gt;</span>
<span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="25:1-25:61">Passo 2: Criar a Lógica para Exibir a História em <code>ui.js</code></h3><p data-sourcepos="27:1-27:82">Agora, vamos criar uma função em <code>ui.js</code> dedicada a mostrar as telas de narrativa.</p><p data-sourcepos="29:1-29:69"><strong>No arquivo <code>ECOM00_jogo/src/js/ui.js</code>, adicione este novo código:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-289 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-289 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-289 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-289">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-289 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-289 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-289"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-289"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-289"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-289" data-sourcepos="31:1-94:1"><span class="hljs-comment">// Adicione esta importação no topo do arquivo ui.js</span>
<span class="hljs-keyword">import</span> { gameState } <span class="hljs-keyword">from</span> <span class="hljs-string">'./gameState.js'</span>;

<span class="hljs-comment">// ... (sua função drawHUD existente) ...</span>

<span class="hljs-comment">// Adicione esta nova função ao final do arquivo</span>
<span class="hljs-keyword">export</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">showNarrativeScreen</span>(<span class="hljs-params">title, subtitle, onComplete</span>) </span>{
  <span class="hljs-keyword">const</span> screen = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-screen"</span>);
  <span class="hljs-keyword">const</span> titleEl = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-title"</span>);
  <span class="hljs-keyword">const</span> subtitleEl = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-subtitle"</span>);
  <span class="hljs-keyword">const</span> restartButton = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"restart-button"</span>);
  <span class="hljs-keyword">const</span> continueButton = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"continue-button"</span>);

  titleEl.textContent = title;
  subtitleEl.textContent = subtitle;
  titleEl.style.color = <span class="hljs-string">'#ffc107'</span>; <span class="hljs-comment">// Cor de ouro para a narrativa</span>

  restartButton.classList.add(<span class="hljs-string">'hidden'</span>);
  continueButton.classList.remove(<span class="hljs-string">'hidden'</span>);
  screen.classList.remove(<span class="hljs-string">'hidden'</span>);

  <span class="hljs-comment">// Pausa o jogo enquanto a história é exibida</span>
  gameState.isPaused = <span class="hljs-literal">true</span>;

  <span class="hljs-keyword">const</span> clickHandler = <span class="hljs-function">() =&gt;</span> {
    screen.classList.add(<span class="hljs-string">'hidden'</span>);
    continueButton.classList.add(<span class="hljs-string">'hidden'</span>);
    gameState.isPaused = <span class="hljs-literal">false</span>;
    <span class="hljs-comment">// Remove o listener para não ser chamado múltiplas vezes</span>
    continueButton.removeEventListener(<span class="hljs-string">'click'</span>, clickHandler);
    <span class="hljs-keyword">if</span> (onComplete) {
      onComplete();
    }
  };

  continueButton.addEventListener(<span class="hljs-string">'click'</span>, clickHandler, { <span class="hljs-attr">once</span>: <span class="hljs-literal">true</span> });
}


<span class="hljs-comment">// Modifique a função showEndScreen para garantir que os botões corretos apareçam</span>
<span class="hljs-keyword">export</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">showEndScreen</span>(<span class="hljs-params">didWin</span>) </span>{
  <span class="hljs-keyword">const</span> screen = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-screen"</span>);
  <span class="hljs-keyword">const</span> title = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-title"</span>);
  <span class="hljs-keyword">const</span> subtitle = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-subtitle"</span>);
  <span class="hljs-keyword">const</span> restartButton = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"restart-button"</span>);
  <span class="hljs-keyword">const</span> continueButton = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"continue-button"</span>);

  <span class="hljs-keyword">if</span> (didWin) {
    title.textContent = <span class="hljs-string">"Você Venceu!"</span>;
    title.style.color = <span class="hljs-string">"#2ecc71"</span>;
    subtitle.textContent = <span class="hljs-string">"O tesouro é seu, mas a montanha treme... A aventura continua!"</span>;
  } <span class="hljs-keyword">else</span> {
    title.textContent = <span class="hljs-string">"Game Over"</span>;
    title.style.color = <span class="hljs-string">"#ff4136"</span>;
    subtitle.textContent = <span class="hljs-string">"A escuridão venceu desta vez."</span>;
  }
  
  <span class="hljs-comment">// Garante que o botão correto está visível</span>
  continueButton.classList.add(<span class="hljs-string">'hidden'</span>);
  restartButton.classList.remove(<span class="hljs-string">'hidden'</span>);
  screen.classList.remove(<span class="hljs-string">"hidden"</span>);
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="96:1-96:64">Passo 3: Definir os Textos e Chamar a Tela em <code>gameLogic.js</code></h3><p data-sourcepos="98:1-98:120">Aqui, definiremos a história de cada fase e modificaremos a lógica de conclusão de fase para chamar a tela de narrativa.</p><p data-sourcepos="100:1-100:82"><strong>No arquivo <code>ECOM00_jogo/src/js/gameLogic.js</code>, adicione e modifique o seguinte:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-290 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-290 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-290 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-290">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-290 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-290 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-290"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-290"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-290"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-290" data-sourcepos="102:1-164:1"><span class="hljs-comment">// Adicione a importação no topo do arquivo</span>
<span class="hljs-keyword">import</span> { showNarrativeScreen, showEndScreen } <span class="hljs-keyword">from</span> <span class="hljs-string">'./ui.js'</span>;

<span class="hljs-comment">// Adicione este objeto com os textos da história perto do topo do arquivo</span>
<span class="hljs-keyword">const</span> narrativeTexts = {
  <span class="hljs-number">1</span>: { <span class="hljs-comment">// Texto para iniciar a Fase 2</span>
    <span class="hljs-attr">title</span>: <span class="hljs-string">"Um Eco nas Profundezas"</span>,
    <span class="hljs-attr">subtitle</span>: <span class="hljs-string">"Você sobreviveu à primeira horda. Um calor estranho emana das paredes de rocha e um eco distante ressoa pela masmorra."</span>
  },
  <span class="hljs-number">2</span>: { <span class="hljs-comment">// Texto para iniciar a Fase 3</span>
    <span class="hljs-attr">title</span>: <span class="hljs-string">"O Ar se Torna rarefeito"</span>,
    <span class="hljs-attr">subtitle</span>: <span class="hljs-string">"Inimigos mais fortes surgem das sombras. O ar fica denso e a escuridão parece querer te engolir. O tesouro deve estar perto."</span>
  },
  <span class="hljs-number">3</span>: { <span class="hljs-comment">// Texto para iniciar a Fase 4</span>
    <span class="hljs-attr">title</span>: <span class="hljs-string">"O Coração do Vulcão"</span>,
    <span class="hljs-attr">subtitle</span>: <span class="hljs-string">"O chão treme sob seus pés! Cinzas caem do teto e rios de lava brilham ao longe. A masmorra é o interior de um vulcão adormecido!"</span>
  },
  <span class="hljs-number">4</span>: { <span class="hljs-comment">// Texto para iniciar a Fase 5 (Chefe)</span>
    <span class="hljs-attr">title</span>: <span class="hljs-string">"O Guardião Ancestral"</span>,
    <span class="hljs-attr">subtitle</span>: <span class="hljs-string">"Você chegou à câmara final. O tesouro está à vista, mas uma criatura colossal, forjada em fogo e rocha, desperta para protegê-lo."</span>
  }
};


<span class="hljs-comment">// ... (suas outras funções como isColliding, spawnEnemy, etc.) ...</span>


<span class="hljs-comment">// Substitua COMPLETAMENTE sua função checkPhaseCompletion por esta versão</span>
<span class="hljs-keyword">export</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">checkPhaseCompletion</span>(<span class="hljs-params"></span>) </span>{
    <span class="hljs-keyword">const</span> config = phaseConfigs[gameState.phase]; 
    <span class="hljs-keyword">if</span> (!config) <span class="hljs-keyword">return</span>;
    
    <span class="hljs-keyword">let</span> completed = <span class="hljs-literal">false</span>;
    <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"survive"</span>) { 
        <span class="hljs-keyword">const</span> timeElapsed = (<span class="hljs-built_in">Date</span>.now() - gameState.phaseStartTime) / <span class="hljs-number">1000</span>; 
        <span class="hljs-keyword">if</span> (timeElapsed &gt;= config.duration) completed = <span class="hljs-literal">true</span>; 
    } <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"defeat"</span>) { 
        <span class="hljs-keyword">if</span> (gameState.score &gt;= config.killTarget) completed = <span class="hljs-literal">true</span>; 
    } <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"reach_portal"</span>) { 
        <span class="hljs-keyword">if</span> (gameState.portal &amp;&amp; isColliding(gameState.player, gameState.portal)) completed = <span class="hljs-literal">true</span>; 
    } <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"defeat_boss"</span>) { 
        <span class="hljs-keyword">if</span> (gameState.enemies.length === <span class="hljs-number">0</span> &amp;&amp; gameState.phaseStartTime &gt; <span class="hljs-number">0</span>) completed = <span class="hljs-literal">true</span>; 
    }

    <span class="hljs-keyword">if</span> (completed) {
        <span class="hljs-keyword">const</span> nextPhase = gameState.phase + <span class="hljs-number">1</span>;
        <span class="hljs-keyword">if</span> (nextPhase &lt; phaseConfigs.length) { 
            <span class="hljs-keyword">const</span> story = narrativeTexts[nextPhase -<span class="hljs-number">1</span>];
            <span class="hljs-keyword">if</span> (story) {
                showNarrativeScreen(story.title, story.subtitle, <span class="hljs-function">() =&gt;</span> {
                    setupPhase(nextPhase); 
                });
            } <span class="hljs-keyword">else</span> {
                setupPhase(nextPhase);
            }
        } <span class="hljs-keyword">else</span> { 
            gameState.isGameOver = <span class="hljs-literal">true</span>; 
            showEndScreen(<span class="hljs-literal">true</span>);
        }
    }
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="166:1-166:50">Passo 4: Exibir a Introdução ao Iniciar o Jogo</h3><p data-sourcepos="168:1-168:112">Finalmente, vamos chamar a tela de narrativa com o texto introdutório quando o jogador clicar em "Iniciar Jogo".</p><p data-sourcepos="170:1-170:87"><strong>No arquivo <code>ECOM00_jogo/src/js/main.js</code>, substitua sua função <code>startGame</code> por esta:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-291 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-291 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-291 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-291">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-291 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-291 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-291"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-291"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-291"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-291" data-sourcepos="172:1-204:1"><span class="hljs-comment">// Em main.js, adicione a importação de showNarrativeScreen</span>
<span class="hljs-keyword">import</span> { showNarrativeScreen, drawHUD, showEndScreen } <span class="hljs-keyword">from</span> <span class="hljs-string">'./ui.js'</span>;


<span class="hljs-comment">// ... (outras funções) ...</span>


<span class="hljs-comment">// Substitua a função startGame inteira</span>
<span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">startGame</span>(<span class="hljs-params"></span>) </span>{
    startMenu.classList.add(<span class="hljs-string">'hidden'</span>);
    hud.classList.remove(<span class="hljs-string">'hidden'</span>);
    gameContainer.classList.remove(<span class="hljs-string">'hidden'</span>);
    playMusicOnFirstInteraction();
    
    <span class="hljs-comment">// Prepara o jogo, mas não inicia o loop ainda</span>
    init();
    
    <span class="hljs-comment">// Mostra a introdução da história primeiro</span>
    showNarrativeScreen(
      <span class="hljs-string">"A Lenda da Masmorra de Fogo"</span>,
      <span class="hljs-string">"Reza a lenda que um grande tesouro se esconde nas profundezas de uma masmorra esquecida, no coração de uma montanha de fogo. Muitos tentaram... todos falharam. Você ousa entrar?"</span>,
      <span class="hljs-function">() =&gt;</span> {
        <span class="hljs-comment">// Quando o jogador clica em "Continuar", a primeira fase começa</span>
        setupPhase(<span class="hljs-number">0</span>);
        <span class="hljs-keyword">if</span> (!isGameLoopRunning) {
            isGameLoopRunning = <span class="hljs-literal">true</span>;
            requestAnimationFrame(gameLoop);
        }
      }
    );
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="206:1-206:79"><strong>E faça uma pequena alteração na função <code>init</code> no mesmo arquivo (<code>main.js</code>):</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-292 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-292 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-292 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-292">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-292 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-292 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_9e40fc8c83184a17&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_894f7174ddf33135&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-292"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-292"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-292"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-292" data-sourcepos="208:1-221:1"><span class="hljs-comment">// Em main.js, altere a função init</span>
<span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">init</span>(<span class="hljs-params"></span>) </span>{
  resetGameState();
  messageScreen.classList.add(<span class="hljs-string">"hidden"</span>);
  pauseMenu.classList.add(<span class="hljs-string">"hidden"</span>);
  gameState.player = <span class="hljs-keyword">new</span> Player(MAP_WIDTH / <span class="hljs-number">2</span>, MAP_HEIGHT - PLAYABLE_AREA_BORDER - <span class="hljs-number">60</span>, <span class="hljs-number">40</span>, <span class="hljs-number">60</span>, <span class="hljs-number">4</span>, images.player_frente);
  <span class="hljs-comment">// Remova a linha abaixo daqui. Ela será chamada após a tela de história.</span>
  <span class="hljs-comment">// setupPhase(0); </span>
  
  <span class="hljs-comment">// O gameLoop também não deve iniciar aqui</span>
  <span class="hljs-comment">// if (!isGameLoopRunning) { ... }</span>
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="223:1-223:168">Com essas alterações, seu jogo agora terá uma introdução e pequenas pausas narrativas que enriquecerão a experiência do jogador, guiando-o pela "Aventura na Masmorra"!</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted"><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-280"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-293 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-293"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-293 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-293 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="Boa resposta" aria-label=