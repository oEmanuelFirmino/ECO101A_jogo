 generated-images"><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><generated-image _nghost-ng-c939924418="" class="ng-star-inserted" style="aspect-ratio: 1 / 1;"><div _ngcontent-ng-c939924418="" class="loader animate"></div><single-image _ngcontent-ng-c939924418="" class="generated-image large" _nghost-ng-c133898763="" data-image-attachment-index="0" jslog="185864;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_03809e8997bd1fd8&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9343f435a6234d4a&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><div _ngcontent-ng-c133898763="" replace-fife-images-at-export="" class="image-container replace-fife-images-at-export ng-star-inserted"><div _ngcontent-ng-c133898763="" class="overlay-container ng-star-inserted"><!----><!----><button _ngcontent-ng-c133898763="" class="image-button ng-star-inserted" jslog="181501;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_03809e8997bd1fd8&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9343f435a6234d4a&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><img _ngcontent-ng-c133898763="" class="image loaded" alt="Imagem de " src="./hud-background_files/unnamed(2).png"></button><!----><!----><!----><!----><div _ngcontent-ng-c939924418="" overlay="" hide-from-message-actions="" class="generated-image-controls hide-from-message-actions ng-star-inserted"><download-generated-image-button _ngcontent-ng-c939924418="" _nghost-ng-c3892761706=""><button _ngcontent-ng-c3892761706="" mat-button="" aria-label="Baixar imagem no tamanho original" mattooltip="Baixar no tamanho original" data-test-id="download-generated-image-button" class="mdc-button mat-mdc-button-base mat-mdc-tooltip-trigger generated-image-button on-hover-button mat-mdc-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="185865;track:generic_click;BardVeMetadataKey:[[&quot;r_03809e8997bd1fd8&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9343f435a6234d4a&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true" aria-describedby="cdk-describedby-message-ng-1-255" cdk-describedby-host="ng-1"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c3892761706="" class="button-icon-wrapper"><!----><mat-icon _ngcontent-ng-c3892761706="" role="img" fonticon="download" class="mat-icon notranslate button-icon google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="download"></mat-icon><!----></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></download-generated-image-button></div><!----><!----><!----></div><!----><!----></div><!----><!----><!----><!----><!----><!----><!----></single-image></generated-image><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element></div></p><p data-sourcepos="5:1-5:26"><strong>Para usar esta imagem:</strong></p><ol data-sourcepos="7:1-10:0">
<li data-sourcepos="7:1-7:95"><strong>Salve a imagem</strong> no seu computador (clique com o botão direito -&gt; Salvar imagem como...).</li>
<li data-sourcepos="8:1-8:41">Renomeie o arquivo para <code>vulcan.png</code>.</li>
<li data-sourcepos="9:1-10:0">Mova o arquivo <code>vulcan.png</code> para a pasta <code>images</code> do seu projeto, substituindo o fundo antigo se necessário.</li>
</ol><p data-sourcepos="11:1-11:139">O jogo já está configurado para carregar <code>vulcan.png</code> para a fase 4, então ele deve aparecer automaticamente na próxima vez que você jogar.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted" style=""><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-431"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-435 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-435"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-435 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-435 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="Boa resposta" aria-label="Boa resposta" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger icon-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-pressed="false" aria-controls="feedback-form-31" jslog="173913;track:generic_click,impression;BardVeMetadataKey