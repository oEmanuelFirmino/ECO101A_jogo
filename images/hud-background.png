  <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">class</span>=<span class="hljs-string">"hud-top"</span>&gt;</span>
    <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"player-health-container"</span>&gt;</span>
      <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"player-health-bar"</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
      <span class="hljs-tag">&lt;<span class="hljs-name">span</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"player-health-text"</span>&gt;</span>100<span class="hljs-tag">&lt;/<span class="hljs-name">span</span>&gt;</span>
    <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>

    <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">class</span>=<span class="hljs-string">"hud-stats"</span>&gt;</span>
      <span class="hljs-tag">&lt;<span class="hljs-name">p</span>&gt;</span>Fase: <span class="hljs-tag">&lt;<span class="hljs-name">span</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"phase-text"</span>&gt;</span>1<span class="hljs-tag">&lt;/<span class="hljs-name">span</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
      <span class="hljs-tag">&lt;<span class="hljs-name">p</span>&gt;</span>Pontos: <span class="hljs-tag">&lt;<span class="hljs-name">span</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"score-text"</span>&gt;</span>0<span class="hljs-tag">&lt;/<span class="hljs-name">span</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
    <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>

    <span class="hljs-tag">&lt;<span class="hljs-name">button</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"pause-button"</span>&gt;</span>Pause<span class="hljs-tag">&lt;/<span class="hljs-name">button</span>&gt;</span>
  <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
  <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">class</span>=<span class="hljs-string">"hud-bottom"</span>&gt;</span>
    <span class="hljs-tag">&lt;<span class="hljs-name">p</span> <span class="hljs-attr">id</span>=<span class="hljs-string">"objective-text"</span>&gt;</span><span class="hljs-tag">&lt;/<span class="hljs-name">p</span>&gt;</span>
  <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
<span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="131:1-131:171">Com o CSS ajustado para forçar a barra de vida a manter seu tamanho e a estrutura do HTML confirmada, a barra <strong>deve</strong> aparecer como esperado no canto esquerdo do seu HUD.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted"><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-176"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-184 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-184"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-184 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-184 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="Boa resp