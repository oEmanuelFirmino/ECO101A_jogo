city="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_2873)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M14.987000465393066,0.621999979019165 C14.66100025177002,8.61299991607666 8.069999694824219,15 0,15 C-3.3469998836517334,15 -6.440000057220459,13.901000022888184 -8.937000274658203,12.045000076293945"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_2869)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2865)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2861)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2854)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div><!----><!----></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c3358885363="" class="response-container-content ng-tns-c3358885363-207 has-thoughts"><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c927349975="" class="response-content ng-tns-c3358885363-207"><!----><model-thoughts _ngcontent-ng-c927349975="" _nghost-ng-c1786796508="" class="ng-tns-c1786796508-209 ng-star-inserted" style="height: auto;"><div _ngcontent-ng-c1786796508="" class="model-thoughts ng-tns-c1786796508-209"><div _ngcontent-ng-c1786796508="" class="thoughts-header ng-tns-c1786796508-209"><button _ngcontent-ng-c1786796508="" mat-button="" data-test-id="thoughts-header-button" class="mdc-button mat-mdc-button-base thoughts-header-button ng-tns-c1786796508-209 mat-mdc-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="247951;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-content"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-label ng-tns-c1786796508-209"><span _ngcontent-ng-c1786796508="" class="ng-tns-c1786796508-209">Mostrar raciocínio</span></div><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-icons ng-tns-c1786796508-209"><!----><mat-icon _ngcontent-ng-c1786796508="" role="img" fonticon="expand_more" class="mat-icon notranslate thoughts-header-button-icon ng-tns-c1786796508-209 google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="expand_more"></mat-icon><!----></div></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button></div><!----></div></model-thoughts><!----><!----><!----><!----><message-content _ngcontent-ng-c927349975="" class="model-response-text ng-star-inserted has-thoughts" _nghost-ng-c3841436833="" id="message-content-id-r_37e66dc1423400f0" style="height: auto;"><div _ngcontent-ng-c3841436833="" class="markdown markdown-main-panel stronger enable-updated-hr-color" id="model-response-message-contentr_37e66dc1423400f0" dir="ltr" style="--animation-duration: 400ms; --fade-animation-function: linear;"><p data-sourcepos="1:1-1:96">Ok, vamos ajustar isso! O bom é que agora você tem o controle total e é bem simples de alterar.</p><p data-sourcepos="3:1-3:140">O "painel de controle" para o tamanho do seu projétil está no arquivo <code>ECOM00_jogo/src/js/entities.js</code>, dentro da função de tiro do jogador.</p><ol data-sourcepos="5:1-8:0">
<li data-sourcepos="5:1-5:56"><strong>Abra o arquivo:</strong> <code>ECOM00_jogo/src/js/entities.js</code></li>
<li data-sourcepos="6:1-6:35"><strong>Encontre a classe:</strong> <code>Player</code></li>
<li data-sourcepos="7:1-8:0"><strong>Vá para o método:</strong> <code>shoot(direction)</code></li>
</ol><p data-sourcepos="9:1-9:50">Dentro desse método, você encontrará estas linhas:</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-212 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-212 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_37e66dc1423400f0&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_c830be8d5f50b8d7&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-212 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-212">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-212 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-212 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_37e66dc1423400f0&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_c830be8d5f50b8d7&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-212"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-212"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-212"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-212" data-sourcepos="11:1-24:22"><span class="hljs-comment">// Dentro do método shoot</span>

<span class="hljs-comment">// &lt;&lt;&lt; EXPERIMENTE COM ESTES VALORES! &gt;&gt;&gt;</span>
<span class="hljs-comment">// Tamanho do projétil na tela (visual)</span>
<span class="hljs-keyword">const</span> visualWidth = <span class="hljs-number">25</span>;
<span class="hljs-keyword">const</span> visualHeight = <span class="hljs-number">11</span>;

<span class="hljs-comment">// Tamanho da área de colisão (hitbox)</span>
<span class="hljs-keyword">const</span> hitboxWidth = <span class="hljs-number">20</span>;
<span class="hljs-keyword">const</span> hitboxHeight = <span class="hljs-number">8</span>;

<span class="hljs-comment">// ... resto da função</span>
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="26:1-26:28">Como Aumentar o Tamanho:</h3><p data-sourcepos="28:1-28:145">Para que o projétil <strong>apareça maior na tela</strong>, você só precisa aumentar os valores das duas primeiras constantes: <code>visualWidth</code> e <code>visualHeight</code>.</p><p data-sourcepos="30:1-30:59"><strong>Por exemplo, tente dobrar os valores para ver o efeito:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-213 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-213 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_37e66dc1423400f0&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_c830be8d5f50b8d7&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-213 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-213">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-213 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-213 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_37e66dc1423400f0&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_c830be8d5f50b8d7&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-213"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-213"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-213"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-213" data-sourcepos="32:1-36:34"><span class="hljs-comment">// Exemplo com valores maiores:</span>
<span class="hljs-keyword">const</span> visualWidth = <span class="hljs-number">50</span>;  <span class="hljs-comment">// Era 25</span>
<span class="hljs-keyword">const</span> visualHeight = <span class="hljs-number">22</span>; <span class="hljs-comment">// Era 11</span>
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="38:1-38:163">Mantenha a proporção entre os dois valores para que o sprite não fique esticado. Vá alterando e testando no jogo até encontrar o tamanho perfeito para o seu gosto.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted"><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-207"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-214 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-214"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-214 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-214 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="Boa resposta" aria-label="Boa r