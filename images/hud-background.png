top offset="52%" stop-color="rgb(84,143,253)"></stop><stop offset="78%" stop-color="rgb(161,144,255)"></stop><stop offset="89%" stop-color="rgb(175,148,254)"></stop><stop offset="100%" stop-color="rgb(189,153,254)"></stop></lineargradient><radialgradient id="__lottie_element_2593" spreadMethod="pad" gradientUnits="userSpaceOnUse" cx="1026" cy="0" r="2013" fx="1026" fy="0"><stop offset="0%" stop-color="rgb(214,99,92)"></stop><stop offset="25%" stop-color="rgb(214,96,97)"></stop><stop offset="50%" stop-color="rgb(214,92,103)"></stop><stop offset="75%" stop-color="rgb(186,103,145)"></stop><stop offset="100%" stop-color="rgb(158,114,186)"></stop></radialgradient><mask id="__lottie_element_2586_1" mask-type="alpha"><use href="#__lottie_element_2586"></use></mask></defs><g clip-path="url(#__lottie_element_2579)"><g mask="url(#__lottie_element_2586_1)" style="display: block;"><g transform="matrix(0.01600000075995922,0,0,0.01600000075995922,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path fill="url(#__lottie_element_2593)" fill-opacity="1" d=" M0,-1000 C551.9000244140625,-1000 1000,-551.9000244140625 1000,0 C1000,551.9000244140625 551.9000244140625,1000 0,1000 C-551.9000244140625,1000 -1000,551.9000244140625 -1000,0 C-1000,-551.9000244140625 -551.9000244140625,-1000 0,-1000z"></path></g></g></g></g></svg></div><!----><!----><!----><!----></div></div><!----><!----></div><!----><!----><div _ngcontent-ng-c3304910809="" lottie-animation="" class="avatar_spinner_animation ng-tns-c3304910809-188 ng-star-inserted" style="opacity: 0; visibility: hidden;"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 32 32" width="32" height="32" preserveAspectRatio="xMidYMid meet" style="width: 100%; height: 100%; transform: translate3d(0px, 0px, 0px); content-visibility: visible;"><defs><clippath id="__lottie_element_2594"><rect width="32" height="32" x="0" y="0"></rect></clippath><lineargradient id="__lottie_element_2598" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_2605" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_2609" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_2613" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="-6" y1="6" x2="16" y2="-16"><stop offset="0%" stop-color="rgb(214,99,92)"></stop><stop offset="50%" stop-color="rgb(186,107,139)"></stop><stop offset="100%" stop-color="rgb(158,114,186)"></stop></lineargradient><lineargradient id="__lottie_element_2617" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="-6" y1="6" x2="16" y2="-16"><stop offset="0%" stop-color="rgb(214,99,92)"></stop><stop offset="50%" stop-color="rgb(186,107,139)"></stop><stop offset="100%" stop-color="rgb(158,114,186)"></stop></lineargradient><lineargradient id="__lottie_element_2621" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="-6" y1="6" x2="16" y2="-16"><stop offset="0%" stop-color="rgb(214,99,92)"></stop><stop offset="50%" stop-color="rgb(186,107,139)"></stop><stop offset="100%" stop-color="rgb(158,114,186)"></stop></lineargradient></defs><g clip-path="url(#__lottie_element_2594)"><g transform="matrix(1,0,0,1,16,16)" opacity="1" style="display: block;"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_2621)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_2617)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M5.302999973297119,-14.034000396728516 C10.968000411987305,-11.890000343322754 15,-6.4120001792907715 15,0 C15,0.8370000123977661 14.930999755859375,1.6579999923706055 14.798999786376953,2.4579999446868896"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_2613)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2609)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2605)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2598)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div><!----><!----></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c3358885363="" class="response-container-content ng-tns-c3358885363-187 has-thoughts"><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c927349975="" class="response-content ng-tns-c3358885363-187"><!----><model-thoughts _ngcontent-ng-c927349975="" _nghost-ng-c1786796508="" class="ng-tns-c1786796508-189 ng-star-inserted" style="height: auto;"><div _ngcontent-ng-c1786796508="" class="model-thoughts ng-tns-c1786796508-189"><div _ngcontent-ng-c1786796508="" class="thoughts-header ng-tns-c1786796508-189"><button _ngcontent-ng-c1786796508="" mat-button="" data-test-id="thoughts-header-button" class="mdc-button mat-mdc-button-base thoughts-header-button ng-tns-c1786796508-189 mat-mdc-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="247951;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-content"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-label ng-tns-c1786796508-189"><span _ngcontent-ng-c1786796508="" class="ng-tns-c1786796508-189">Mostrar raciocínio</span></div><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-icons ng-tns-c1786796508-189"><!----><mat-icon _ngcontent-ng-c1786796508="" role="img" fonticon="expand_more" class="mat-icon notranslate thoughts-header-button-icon ng-tns-c1786796508-189 google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="expand_more"></mat-icon><!----></div></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button></div><!----></div></model-thoughts><!----><!----><!----><!----><message-content _ngcontent-ng-c927349975="" class="model-response-text ng-star-inserted has-thoughts" _nghost-ng-c3841436833="" id="message-content-id-r_d0dd98deb227c991" style="height: auto;"><div _ngcontent-ng-c3841436833="" class="markdown markdown-main-panel stronger enable-updated-hr-color" id="model-response-message-contentr_d0dd98deb227c991" dir="ltr" style="--animation-duration: 400ms; --fade-animation-function: linear;"><p data-sourcepos="1:1-1:206">KSKSKSK ok, sem problemas! Isso acontece porque, na última alteração, fizemos o jogo desenhar o projétil usando o tamanho original do arquivo <code>bullet.png</code>, e ele é maior do que o ideal para a tela do jogo.</p><p data-sourcepos="3:1-3:202">A boa notícia é que a estrutura que criamos para separar a <code>hitbox</code> do visual é perfeita para resolver isso. Só precisamos fazer um pequeno ajuste para controlar o tamanho da imagem na hora de desenhar.</p><p data-sourcepos="5:1-5:89">Tudo o que você precisa mudar está em um único arquivo: <code>ECOM00_jogo/src/js/entities.js</code>.</p><hr data-sourcepos="7:1-7:5"><h3 data-sourcepos="9:1-9:51">Passo 1: Atualizar o Construtor do <code>Projectile</code></h3><p data-sourcepos="11:1-11:133">Vamos dizer ao nosso projétil para aceitar e armazenar as dimensões visuais que queremos que ele tenha, além das dimensões da hitbox.</p><p data-sourcepos="13:1-13:80"><strong>Em <code>entities.js</code>, substitua o <code>constructor</code> da classe <code>Projectile</code> por este:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-193 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-193 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_d0dd98deb227c991&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_a41501fd455d2c5b&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-193 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-193">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-193 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-193 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_d0dd98deb227c991&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_a41501fd455d2c5b&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-193"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-193"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-193"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-193" data-sourcepos="15:1-29:1"><span class="hljs-comment">// Dentro da classe Projectile</span>
<span class="hljs-function"><span class="hljs-title">constructor</span>(<span class="hljs-params">x, y, hitboxWidth, hitboxHeight, visualWidth, visualHeight, sprite, vx, vy, direction</span>)</span> {
    <span class="hljs-comment">// 'width' e 'height' continuam sendo para a HITBOX</span>
    <span class="hljs-built_in">super</span>(x, y, hitboxWidth, height, <span class="hljs-number">0</span>, sprite);
    
    <span class="hljs-comment">// Armazenamos as novas dimensões visuais</span>
    <span class="hljs-built_in">this</span>.visualWidth = visualWidth;
    <span class="hljs-built_in">this</span>.visualHeight = visualHeight;

    <span class="hljs-built_in">this</span>.vx = vx;
    <span class="hljs-built_in">this</span>.vy = vy;
    <span class="hljs-built_in">this</span>.direction = direction; <span class="hljs-comment">// Armazena a direção para o desenho</span>
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="31:1-31:55">Passo 2: Usar o Tamanho Visual na Função de Desenho</h3><p data-sourcepos="33:1-33:110">Agora, vamos dizer à função <code>draw</code> para usar as novas dimensões visuais em vez do tamanho original do arquivo.</p><p data-sourcepos="35:1-35:78"><strong>Ainda na classe <code>Projectile</code>, substitua a sua função <code>draw(ctx)</code> por esta:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-194 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-194 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_d0dd98deb227c991&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_a41501fd455d2c5b&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-194 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-194">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-194 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-194 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_d0dd98deb227c991&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_a41501fd455d2c5b&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-194"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-194"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-194"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-194" data-sourcepos="37:1-62:1"><span class="hljs-comment">// Dentro da classe Projectile</span>
<span class="hljs-function"><span class="hljs-title">draw</span>(<span class="hljs-params">ctx</span>)</span> {
    <span class="hljs-keyword">if</span> (!<span class="hljs-built_in">this</span>.sprite || !<span class="hljs-built_in">this</span>.sprite.complete || <span class="hljs-built_in">this</span>.sprite.naturalWidth === <span class="hljs-number">0</span>) <span class="hljs-keyword">return</span>;

    <span class="hljs-keyword">const</span> centerX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width / <span class="hljs-number">2</span>;
    <span class="hljs-keyword">const</span> centerY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height / <span class="hljs-number">2</span>;
    
    ctx.save();
    ctx.translate(centerX, centerY);

    <span class="hljs-keyword">let</span> angle = <span class="hljs-number">0</span>;
    <span class="hljs-keyword">switch</span> (<span class="hljs-built_in">this</span>.direction) {
        <span class="hljs-keyword">case</span> <span class="hljs-string">'up'</span>:    angle = -<span class="hljs-built_in">Math</span>.PI / <span class="hljs-number">2</span>; <span class="hljs-keyword">break</span>;
        <span class="hljs-keyword">case</span> <span class="hljs-string">'down'</span>:  angle = <span class="hljs-built_in">Math</span>.PI / <span class="hljs-number">2</span>;  <span class="hljs-keyword">break</span>;
        <span class="hljs-keyword">case</span> <span class="hljs-string">'left'</span>:  angle = <span class="hljs-built_in">Math</span>.PI;      <span class="hljs-keyword">break</span>;
    }
    ctx.rotate(angle);

    <span class="hljs-comment">// &lt;&lt;&lt; ALTERAÇÃO PRINCIPAL AQUI &gt;&gt;&gt;</span>
    <span class="hljs-comment">// Agora desenhamos usando o tamanho visual que definimos, não o da imagem</span>
    ctx.drawImage(<span class="hljs-built_in">this</span>.sprite, -<span class="hljs-built_in">this</span>.visualWidth / <span class="hljs-number">2</span>, -<span class="hljs-built_in">this</span>.visualHeight / <span class="hljs-number">2</span>, <span class="hljs-built_in">this</span>.visualWidth, <span class="hljs-built_in">this</span>.visualHeight);

    ctx.restore();
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="64:1-64:52">Passo 3: Definir e Enviar os Tamanhos no Disparo</h3><p data-sourcepos="66:1-66:162">Finalmente, na função <code>shoot</code> do jogador, vamos definir o quão grande (ou pequeno) queremos que o projétil apareça e passar essa informação quando ele for criado.</p><p data-sourcepos="68:1-68:93"><strong>Na classe <code>Player</code>, substitua toda a sua função <code>shoot(direction)</code> por esta versão final:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-195 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-195 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_d0dd98deb227c991&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_a41501fd455d2c5b&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-195 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-195">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-195 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-195 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_d0dd98deb227c991&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_a41501fd455d2c5b&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-195"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-195"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-195"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-195" data-sourcepos="70:1-119:1"><span class="hljs-comment">// Dentro da classe Player</span>
<span class="hljs-function"><span class="hljs-title">shoot</span>(<span class="hljs-params">direction</span>)</span> {
    <span class="hljs-built_in">this</span>.direction = direction;
    <span class="hljs-keyword">let</span> projX, projY, vx = <span class="hljs-number">0</span>, vy = <span class="hljs-number">0</span>;
    <span class="hljs-keyword">const</span> projSpeed = <span class="hljs-number">8</span>;
    
    <span class="hljs-comment">// &lt;&lt;&lt; EXPERIMENTE COM ESTES VALORES! &gt;&gt;&gt;</span>
    <span class="hljs-comment">// Tamanho do projétil na tela (visual)</span>
    <span class="hljs-keyword">const</span> visualWidth = <span class="hljs-number">25</span>; <span class="hljs-comment">// Era o tamanho da imagem, agora é 25px</span>
    <span class="hljs-keyword">const</span> visualHeight = <span class="hljs-number">11</span>; <span class="hljs-comment">// Proporcional à imagem da bala</span>

    <span class="hljs-comment">// Tamanho da área de colisão (hitbox)</span>
    <span class="hljs-keyword">const</span> hitboxWidth = <span class="hljs-number">20</span>;
    <span class="hljs-keyword">const</span> hitboxHeight = <span class="hljs-number">8</span>;

    <span class="hljs-comment">// Ajusta a posição de saída do projétil</span>
    <span class="hljs-keyword">switch</span> (direction) {
      <span class="hljs-keyword">case</span> <span class="hljs-string">"up"</span>: 
        projX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width / <span class="hljs-number">2</span> - hitboxWidth / <span class="hljs-number">2</span>; 
        projY = <span class="hljs-built_in">this</span>.y - hitboxHeight; 
        vy = -projSpeed; 
        <span class="hljs-keyword">break</span>;
      <span class="hljs-keyword">case</span> <span class="hljs-string">"down"</span>: 
        projX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width / <span class="hljs-number">2</span> - hitboxWidth / <span class="hljs-number">2</span>; 
        projY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height; 
        vy = projSpeed; 
        <span class="hljs-keyword">break</span>;
      <span class="hljs-keyword">case</span> <span class="hljs-string">"left"</span>: 
        projX = <span class="hljs-built_in">this</span>.x - hitboxWidth; 
        projY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height / <span class="hljs-number">2</span> - hitboxHeight / <span class="hljs-number">2</span>; 
        vx = -projSpeed; 
        <span class="hljs-keyword">break</span>;
      <span class="hljs-keyword">case</span> <span class="hljs-string">"right"</span>: 
        projX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width; 
        projY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height / <span class="hljs-number">2</span> - hitboxHeight / <span class="hljs-number">2</span>; 
        vx = projSpeed; 
        <span class="hljs-keyword">break</span>;
    }

    <span class="hljs-keyword">if</span> (vx !== <span class="hljs-number">0</span> || vy !== <span class="hljs-number">0</span>) {
      <span class="hljs-comment">// &lt;&lt;&lt; Passamos os 4 valores de tamanho para o novo projétil &gt;&gt;&gt;</span>
      gameState.projectiles.push(
        <span class="hljs-keyword">new</span> Projectile(projX, projY, hitboxWidth, hitboxHeight, visualWidth, visualHeight, images.projectile, vx, vy, direction)
      );
      gameState.canShoot = <span class="hljs-literal">false</span>;
      <span class="hljs-built_in">setTimeout</span>(<span class="hljs-function">() =&gt;</span> { gameState.canShoot = <span class="hljs-literal">true</span>; }, gameState.shootCooldown);
    }
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="121:1-121:159">Agora você tem controle total! Vá na função <code>shoot</code> e altere os valores de <code>visualWidth</code> e <code>visualHeight</code> até o projétil ficar do tamanho exato que você quer.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted"><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-187"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-196 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-196"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-196 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-196 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="B