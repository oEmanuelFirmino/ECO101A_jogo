lottie_element_6325)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_6321)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_6317)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_6310)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div><!----><!----></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c3358885363="" class="response-container-content ng-tns-c3358885363-483 has-thoughts"><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c927349975="" class="response-content ng-tns-c3358885363-483"><!----><model-thoughts _ngcontent-ng-c927349975="" _nghost-ng-c1786796508="" class="ng-tns-c1786796508-485 ng-star-inserted" style="height: auto;"><div _ngcontent-ng-c1786796508="" class="model-thoughts ng-tns-c1786796508-485"><div _ngcontent-ng-c1786796508="" class="thoughts-header ng-tns-c1786796508-485"><button _ngcontent-ng-c1786796508="" mat-button="" data-test-id="thoughts-header-button" class="mdc-button mat-mdc-button-base thoughts-header-button ng-tns-c1786796508-485 mat-mdc-button mat-unthemed" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="247951;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-content"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-label ng-tns-c1786796508-485"><span _ngcontent-ng-c1786796508="" class="ng-tns-c1786796508-485">Mostrar raciocínio</span></div><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-icons ng-tns-c1786796508-485"><!----><mat-icon _ngcontent-ng-c1786796508="" role="img" fonticon="expand_more" class="mat-icon notranslate thoughts-header-button-icon ng-tns-c1786796508-485 google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="expand_more"></mat-icon><!----></div></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button></div><!----></div></model-thoughts><!----><!----><!----><!----><message-content _ngcontent-ng-c927349975="" class="model-response-text ng-star-inserted has-thoughts" _nghost-ng-c3841436833="" id="message-content-id-r_dd684466a9ad50b4" style="height: auto;"><div _ngcontent-ng-c3841436833="" class="markdown markdown-main-panel stronger enable-updated-hr-color" id="model-response-message-contentr_dd684466a9ad50b4" dir="ltr" style="--animation-duration: 400ms; --fade-animation-function: linear;"><p data-sourcepos="1:1-1:191">Com certeza! Essa é uma excelente ideia para aumentar a imersão. Vamos criar uma tela de história que pareça um livro ou pergaminho antigo e garantir que o HUD do jogo não apareça por baixo.</p><p data-sourcepos="3:1-3:27">Isso envolverá três passos:</p><ol data-sourcepos="5:1-8:0">
<li data-sourcepos="5:1-5:41">Gerar uma imagem de fundo apropriada.</li>
<li data-sourcepos="6:1-6:60">Ajustar o CSS para usar essa imagem e estilizar o texto.</li>
<li data-sourcepos="7:1-8:0">Ajustar o JavaScript para esconder o HUD quando a história for exibida.</li>
</ol><h3 data-sourcepos="9:1-9:36">Passo 1: Gerar a Imagem de Fundo</h3><p data-sourcepos="11:1-12:49">Primeiro, vou gerar uma imagem de um pergaminho ou página de livro antigo para servir como fundo.
Aqui está uma imagem que podemos usar como fundo.</p><p data-sourcepos="14:1-14:55"><div class="attachment-container generated-images"><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><generated-image _nghost-ng-c939924418="" class="ng-star-inserted" style="aspect-ratio: 1 / 1;"><div _ngcontent-ng-c939924418="" class="loader animate"></div><single-image _ngcontent-ng-c939924418="" class="generated-image large" _nghost-ng-c133898763="" data-image-attachment-index="0" jslog="185864;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><div _ngcontent-ng-c133898763="" replace-fife-images-at-export="" class="image-container replace-fife-images-at-export ng-star-inserted"><div _ngcontent-ng-c133898763="" class="overlay-container ng-star-inserted"><!----><!----><button _ngcontent-ng-c133898763="" class="image-button ng-star-inserted" jslog="181501;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><img _ngcontent-ng-c133898763="" class="image loaded" alt="Imagem de " src="./hud-background_files/unnamed(4).png"></button><!----><!----><!----><!----><div _ngcontent-ng-c939924418="" overlay="" hide-from-message-actions="" class="generated-image-controls hide-from-message-actions ng-star-inserted"><download-generated-image-button _ngcontent-ng-c939924418="" _nghost-ng-c3892761706=""><button _ngcontent-ng-c3892761706="" mat-button="" aria-label="Baixar imagem no tamanho original" mattooltip="Baixar no tamanho original" data-test-id="download-generated-image-button" class="mdc-button mat-mdc-button-base mat-mdc-tooltip-trigger generated-image-button on-hover-button mat-mdc-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="185865;track:generic_click;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true" aria-describedby="cdk-describedby-message-ng-1-255" cdk-describedby-host="ng-1"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c3892761706="" class="button-icon-wrapper"><!----><mat-icon _ngcontent-ng-c3892761706="" role="img" fonticon="download" class="mat-icon notranslate button-icon google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="download"></mat-icon><!----></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></download-generated-image-button></div><!----><!----><!----></div><!----><!----></div><!----><!----><!----><!----><!----><!----><!----></single-image></generated-image><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element></div></p><p data-sourcepos="16:1-16:9"><strong>Ação:</strong></p><ol data-sourcepos="18:1-21:0">
<li data-sourcepos="18:1-18:64"><strong>Salve a imagem</strong> acima na sua pasta <code>ECOM00_jogo/images/</code>.</li>
<li data-sourcepos="19:1-19:55"><strong>Renomeie o arquivo</strong> para <code>story-background.png</code>.</li>
<li data-sourcepos="20:1-21:0"><strong>Lembrete:</strong> Se a imagem não aparecer e você vir apenas um link, copie e cole o link em uma nova aba do seu navegador para poder salvá-la.</li>
</ol><h3 data-sourcepos="22:1-22:46">Passo 2: Esconder o HUD e Ajustar a Lógica</h3><p data-sourcepos="24:1-24:106">Agora, vamos modificar a função que mostra a história para que ela também esconda o HUD principal do jogo.</p><p data-sourcepos="26:1-26:42"><strong>No arquivo <code>ECOM00_jogo/src/js/ui.js</code>:</strong></p><p data-sourcepos="28:1-28:163"><strong>Substitua</strong> a sua função <code>showNarrativeScreen</code> inteira por esta versão aprimorada. Ela agora irá esconder o HUD e mostrá-lo novamente quando o jogador continuar.</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-490 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-490 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-490 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-490">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-490 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-490 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-490"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-490"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-490"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-490" data-sourcepos="30:1-69:1"><span class="hljs-comment">// Substitua a função showNarrativeScreen inteira em ui.js</span>

<span class="hljs-keyword">export</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">showNarrativeScreen</span>(<span class="hljs-params">title, subtitle, onComplete</span>) </span>{
  <span class="hljs-keyword">const</span> screen = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-screen"</span>);
  <span class="hljs-keyword">const</span> titleEl = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-title"</span>);
  <span class="hljs-keyword">const</span> subtitleEl = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"message-subtitle"</span>);
  <span class="hljs-keyword">const</span> restartButton = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"restart-button"</span>);
  <span class="hljs-keyword">const</span> continueButton = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"continue-button"</span>);
  <span class="hljs-keyword">const</span> hud = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"hud"</span>); <span class="hljs-comment">// Pega o elemento do HUD</span>

  <span class="hljs-comment">// Esconde o HUD do jogo</span>
  hud.classList.add(<span class="hljs-string">'hidden'</span>);

  titleEl.textContent = title;
  subtitleEl.textContent = subtitle;
  
  restartButton.classList.add(<span class="hljs-string">'hidden'</span>);
  continueButton.classList.remove(<span class="hljs-string">'hidden'</span>);
  screen.classList.remove(<span class="hljs-string">'hidden'</span>);

  gameState.isPaused = <span class="hljs-literal">true</span>;

  <span class="hljs-keyword">const</span> clickHandler = <span class="hljs-function">() =&gt;</span> {
    screen.classList.add(<span class="hljs-string">'hidden'</span>);
    continueButton.classList.add(<span class="hljs-string">'hidden'</span>);
    
    <span class="hljs-comment">// Mostra o HUD novamente antes de continuar o jogo</span>
    hud.classList.remove(<span class="hljs-string">'hidden'</span>);

    gameState.isPaused = <span class="hljs-literal">false</span>;
    continueButton.removeEventListener(<span class="hljs-string">'click'</span>, clickHandler);
    <span class="hljs-keyword">if</span> (onComplete) {
      onComplete();
    }
  };

  continueButton.addEventListener(<span class="hljs-string">'click'</span>, clickHandler, { <span class="hljs-attr">once</span>: <span class="hljs-literal">true</span> });
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="71:1-71:46">Passo 3: Estilizar a Nova Tela de História</h3><p data-sourcepos="73:1-73:129">Finalmente, vamos aplicar a imagem de fundo e ajustar o estilo do texto para que ele fique legível e temático sobre o novo fundo.</p><p data-sourcepos="75:1-75:46"><strong>No arquivo <code>ECOM00_jogo/src/css/main.css</code>:</strong></p><p data-sourcepos="77:1-77:121"><strong>Substitua</strong> a regra de CSS para <code>#pause-menu, #message-screen</code> por estas duas regras separadas, uma para cada elemento.</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-491 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-491 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-491 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-491">CSS</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-491 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-491 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_dd684466a9ad50b4&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_2cf87bf43b2da706&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-491"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-491"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-491"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-491" data-sourcepos="79:1-131:1"><span class="hljs-comment">/* Em main.css, encontre a regra para #pause-menu, #message-screen e a substitua por isto */</span>

<span class="hljs-comment">/* O menu de pause continua com o fundo escuro */</span>
<span class="hljs-selector-id">#pause-menu</span> {
  <span class="hljs-attribute">position</span>: absolute;
  <span class="hljs-attribute">top</span>: <span class="hljs-number">0</span>; <span class="hljs-attribute">left</span>: <span class="hljs-number">0</span>; <span class="hljs-attribute">width</span>: <span class="hljs-number">100%</span>; <span class="hljs-attribute">height</span>: <span class="hljs-number">100%</span>;
  <span class="hljs-attribute">background-color</span>: <span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.85</span>);
  <span class="hljs-attribute">display</span>: flex;
  <span class="hljs-attribute">flex-direction</span>: column;
  <span class="hljs-attribute">justify-content</span>: center;
  <span class="hljs-attribute">align-items</span>: center;
  <span class="hljs-attribute">text-align</span>: center;
  <span class="hljs-attribute">font-family</span>: <span class="hljs-string">"Press Start 2P"</span>, cursive;
  <span class="hljs-attribute">z-index</span>: <span class="hljs-number">100</span>;
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#fff</span>;
  gap: <span class="hljs-number">20px</span>;
}

<span class="hljs-comment">/* === NOVO ESTILO PARA A TELA DE HISTÓRIA === */</span>
<span class="hljs-selector-id">#message-screen</span> {
  <span class="hljs-attribute">position</span>: absolute;
  <span class="hljs-attribute">top</span>: <span class="hljs-number">0</span>; <span class="hljs-attribute">left</span>: <span class="hljs-number">0</span>; <span class="hljs-attribute">width</span>: <span class="hljs-number">100%</span>; <span class="hljs-attribute">height</span>: <span class="hljs-number">100%</span>;
  
  <span class="hljs-comment">/* Usa a nova imagem de fundo */</span>
  <span class="hljs-attribute">background-image</span>: <span class="hljs-built_in">url</span>(<span class="hljs-string">'/images/story-background.png'</span>);
  <span class="hljs-attribute">background-size</span>: cover;
  <span class="hljs-attribute">background-position</span>: center;
  
  <span class="hljs-attribute">display</span>: flex;
  <span class="hljs-attribute">flex-direction</span>: column;
  <span class="hljs-attribute">justify-content</span>: center;
  <span class="hljs-attribute">align-items</span>: center;
  <span class="hljs-attribute">text-align</span>: center;
  <span class="hljs-attribute">z-index</span>: <span class="hljs-number">100</span>;
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">40px</span>; <span class="hljs-comment">/* Adiciona um respiro nas bordas */</span>
  <span class="hljs-attribute">box-sizing</span>: border-box; <span class="hljs-comment">/* Garante que o padding não estoure o layout */</span>
}

<span class="hljs-comment">/* Ajusta a cor do texto da história para ser legível no fundo claro */</span>
<span class="hljs-selector-id">#message-screen</span> <span class="hljs-selector-id">#message-title</span> {
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#4a2d1b</span>; <span class="hljs-comment">/* Marrom escuro, como tinta antiga */</span>
  <span class="hljs-attribute">text-shadow</span>: <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#d4cbb8</span>; <span class="hljs-comment">/* Sombra clara para dar profundidade */</span>
}

<span class="hljs-selector-id">#message-screen</span> <span class="hljs-selector-id">#message-subtitle</span> {
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#3b2315</span>; <span class="hljs-comment">/* Marrom ainda mais escuro para o corpo do texto */</span>
  <span class="hljs-attribute">font-family</span>: <span class="hljs-string">"VT323"</span>, monospace; <span class="hljs-comment">/* Usa uma fonte mais 'manuscrita' */</span>
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">24px</span>;
  <span class="hljs-attribute">line-height</span>: <span class="hljs-number">1.6</span>;
  <span class="hljs-attribute">max-width</span>: <span class="hljs-number">70%</span>;
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="133:1-133:227">Com essas alterações, ao final de cada fase, o HUD do jogo desaparecerá e, em seu lugar, surgirá uma bela página de livro antigo contando o próximo capítulo da sua aventura, criando uma transição muito mais elegante e imersiva.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted" style=""><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-483"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-492 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-492"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-492 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-492 ng-star-inserted"><button _ngcontent-ng-c1