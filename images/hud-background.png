opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_6822)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div><!----><!----></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c3358885363="" class="response-container-content ng-tns-c3358885363-523 has-thoughts"><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c927349975="" class="response-content ng-tns-c3358885363-523"><!----><model-thoughts _ngcontent-ng-c927349975="" _nghost-ng-c1786796508="" class="ng-tns-c1786796508-525 ng-star-inserted" style="height: auto;"><div _ngcontent-ng-c1786796508="" class="model-thoughts ng-tns-c1786796508-525"><div _ngcontent-ng-c1786796508="" class="thoughts-header ng-tns-c1786796508-525"><button _ngcontent-ng-c1786796508="" mat-button="" data-test-id="thoughts-header-button" class="mdc-button mat-mdc-button-base thoughts-header-button ng-tns-c1786796508-525 mat-mdc-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="247951;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-content"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-label ng-tns-c1786796508-525"><span _ngcontent-ng-c1786796508="" class="ng-tns-c1786796508-525">Mostrar raciocínio</span></div><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-icons ng-tns-c1786796508-525"><!----><mat-icon _ngcontent-ng-c1786796508="" role="img" fonticon="expand_more" class="mat-icon notranslate thoughts-header-button-icon ng-tns-c1786796508-525 google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="expand_more"></mat-icon><!----></div></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button></div><!----></div></model-thoughts><!----><!----><!----><!----><message-content _ngcontent-ng-c927349975="" class="model-response-text ng-star-inserted has-thoughts" _nghost-ng-c3841436833="" id="message-content-id-r_a3f786fe6081e52d" style="height: auto;"><div _ngcontent-ng-c3841436833="" class="markdown markdown-main-panel stronger enable-updated-hr-color" id="model-response-message-contentr_a3f786fe6081e52d" dir="ltr" style="--animation-duration: 400ms; --fade-animation-function: linear;"><p data-sourcepos="1:1-1:191">Com certeza! Vamos fazer este último polimento no HUD para deixá-lo ainda mais discreto e dar à barra de vida um acabamento mais profissional com bordas arredondadas e um gradiente dinâmico.</p><p data-sourcepos="3:1-3:102">Isso envolverá mudanças em dois arquivos: a lógica da cor em <code>ui.js</code> e o estilo/tamanho em <code>main.css</code>.</p><h3 data-sourcepos="5:1-5:59">Passo 1: Lógica do Gradiente da Barra de Vida (<code>ui.js</code>)</h3><p data-sourcepos="7:1-7:160">Primeiro, vamos fazer a barra de vida mudar de cor. Ela terá um gradiente que irá do verde, para o amarelo e para o vermelho conforme a vida do jogador diminui.</p><p data-sourcepos="9:1-9:42"><strong>No arquivo <code>ECOM00_jogo/src/js/ui.js</code>:</strong></p><p data-sourcepos="11:1-11:71"><strong>Substitua</strong> toda a sua função <code>drawHUD()</code> por esta versão aprimorada.</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-528 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-528 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_a3f786fe6081e52d&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9640ea96397b9c21&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-528 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-528">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-528 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-528 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_a3f786fe6081e52d&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9640ea96397b9c21&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-528"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-528"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-528"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-528" data-sourcepos="13:1-71:1"><span class="hljs-comment">// Substitua a função drawHUD inteira em ui.js</span>

<span class="hljs-keyword">export</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">drawHUD</span>(<span class="hljs-params"></span>) </span>{
  <span class="hljs-keyword">if</span> (!gameState.player) <span class="hljs-keyword">return</span>;

  <span class="hljs-comment">// --- LÓGICA DA BARRA DE VIDA DINÂMICA ---</span>
  <span class="hljs-keyword">const</span> playerHealthPercent = (gameState.player.health / gameState.player.maxHealth) * <span class="hljs-number">100</span>;
  <span class="hljs-keyword">const</span> playerHealthBar = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"player-health-bar"</span>);
  
  <span class="hljs-keyword">if</span> (playerHealthBar) {
    <span class="hljs-comment">// Atualiza a largura da barra</span>
    playerHealthBar.style.width = <span class="hljs-string">`<span class="hljs-subst">${playerHealthPercent}</span>%`</span>;

    <span class="hljs-comment">// Define o gradiente da cor com base no percentual de vida</span>
    <span class="hljs-keyword">let</span> healthGradient;
    <span class="hljs-keyword">if</span> (playerHealthPercent &gt; <span class="hljs-number">60</span>) {
      <span class="hljs-comment">// Gradiente Verde (vida alta)</span>
      healthGradient = <span class="hljs-string">'linear-gradient(to right, #63e674, #28a745)'</span>;
    } <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> (playerHealthPercent &gt; <span class="hljs-number">30</span>) {
      <span class="hljs-comment">// Gradiente Amarelo/Laranja (vida média)</span>
      healthGradient = <span class="hljs-string">'linear-gradient(to right, #ffdd57, #ff9f1a)'</span>;
    } <span class="hljs-keyword">else</span> {
      <span class="hljs-comment">// Gradiente Vermelho (vida baixa)</span>
      healthGradient = <span class="hljs-string">'linear-gradient(to right, #e85a5a, #dc3545)'</span>;
    }
    playerHealthBar.style.background = healthGradient;
  }
  
  <span class="hljs-comment">// Atualiza o texto da vida</span>
  <span class="hljs-keyword">const</span> healthText = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"player-health-text"</span>);
  <span class="hljs-keyword">if</span> (healthText) {
    healthText.textContent = gameState.player.health;
  }

  <span class="hljs-comment">// Atualiza o texto da fase</span>
  <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"phase-text"</span>).textContent = gameState.phase + <span class="hljs-number">1</span>;
  
  <span class="hljs-comment">// Atualiza o texto do objetivo</span>
  <span class="hljs-keyword">const</span> config = phaseConfigs[gameState.phase];
  <span class="hljs-keyword">if</span> (!config) <span class="hljs-keyword">return</span>;
  <span class="hljs-keyword">const</span> objectiveText = <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"objective-text"</span>);
  <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"survive"</span>) {
    <span class="hljs-keyword">const</span> timeElapsed = (<span class="hljs-built_in">Date</span>.now() - gameState.phaseStartTime) / <span class="hljs-number">1000</span>;
    <span class="hljs-keyword">const</span> timeLeft = <span class="hljs-built_in">Math</span>.max(<span class="hljs-number">0</span>, <span class="hljs-built_in">Math</span>.ceil(config.duration - timeElapsed));
    objectiveText.textContent = <span class="hljs-string">`Sobreviva! <span class="hljs-subst">${timeLeft}</span>s`</span>;
  } <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"defeat"</span>) {
    objectiveText.textContent = <span class="hljs-string">`Derrote <span class="hljs-subst">${config.killTarget}</span> inimigos (<span class="hljs-subst">${gameState.score}</span>/<span class="hljs-subst">${config.killTarget}</span>)`</span>;
  } <span class="hljs-keyword">else</span> {
    objectiveText.textContent = config.objectiveText;
  }
  
  <span class="hljs-comment">// Lógica da Barra de Vida do Boss</span>
  <span class="hljs-keyword">if</span> (config.objectiveType === <span class="hljs-string">"defeat_boss"</span> &amp;&amp; gameState.enemies[<span class="hljs-number">0</span>]) {
    <span class="hljs-keyword">const</span> bossHealthPercent = (gameState.enemies[<span class="hljs-number">0</span>].health / gameState.enemies[<span class="hljs-number">0</span>].maxHealth) * <span class="hljs-number">100</span>;
    <span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"boss-health-bar"</span>).style.width = <span class="hljs-string">`<span class="hljs-subst">${bossHealthPercent}</span>%`</span>;
  }
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="73:1-73:61">Passo 2: Estilo Final do HUD e Barra de Vida (<code>main.css</code>)</h3><p data-sourcepos="75:1-75:63">Agora vamos aplicar os novos tamanhos e as bordas arredondadas.</p><p data-sourcepos="77:1-77:46"><strong>No arquivo <code>ECOM00_jogo/src/css/main.css</code>:</strong></p><p data-sourcepos="79:1-79:122"><strong>Substitua</strong> a seção de estilos do HUD novamente pela versão abaixo, que é ainda mais compacta e aplica o arredondamento.</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-529 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-529 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_a3f786fe6081e52d&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9640ea96397b9c21&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-529 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-529">CSS</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-529 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-529 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_a3f786fe6081e52d&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_9640ea96397b9c21&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-529"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-529"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-529"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-529" data-sourcepos="81:1-150:1"><span class="hljs-comment">/* === HUD FINAL - VERSÃO 2 (MAIS COMPACTA) === */</span>
<span class="hljs-selector-id">#hud</span> {
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">4px</span> <span class="hljs-number">10px</span>; <span class="hljs-comment">/* Padding mínimo */</span>
  <span class="hljs-attribute">background-color</span>: <span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.4</span>);
  <span class="hljs-attribute">border-bottom</span>: <span class="hljs-number">1px</span> solid <span class="hljs-number">#444</span>; <span class="hljs-comment">/* Borda bem sutil */</span>
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#fff</span>;
  <span class="hljs-attribute">text-shadow</span>: <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> <span class="hljs-number">#000</span>;
}

<span class="hljs-selector-class">.hud-top</span> { 
  <span class="hljs-attribute">display</span>: flex; 
  <span class="hljs-attribute">justify-content</span>: space-between;
  <span class="hljs-attribute">align-items</span>: center;
  <span class="hljs-attribute">position</span>: relative;
  <span class="hljs-attribute">height</span>: <span class="hljs-number">18px</span>; <span class="hljs-comment">/* Altura do HUD superior bem baixa */</span>
}

<span class="hljs-comment">/* Barra de Vida Arredondada */</span>
<span class="hljs-selector-id">#player-health-container</span> {
  <span class="hljs-attribute">position</span>: relative; 
  <span class="hljs-attribute">width</span>: <span class="hljs-number">120px</span>; <span class="hljs-comment">/* Largura final */</span>
  <span class="hljs-attribute">height</span>: <span class="hljs-number">16px</span>; <span class="hljs-comment">/* Altura final */</span>
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#222</span>; <span class="hljs-comment">/* Fundo mais escuro */</span>
  <span class="hljs-attribute">border</span>: <span class="hljs-number">1px</span> solid <span class="hljs-number">#111</span>;
  <span class="hljs-attribute">border-radius</span>: <span class="hljs-number">8px</span>; <span class="hljs-comment">/* &lt;&lt;&lt; BORDAS ARREDONDADAS */</span>
}
<span class="hljs-selector-id">#player-health-bar</span> {
  <span class="hljs-attribute">height</span>: <span class="hljs-number">100%</span>;
  <span class="hljs-attribute">border-radius</span>: <span class="hljs-number">7px</span>; <span class="hljs-comment">/* &lt;&lt;&lt; BORDAS ARREDONDADAS (um pouco menor que o container) */</span>
  <span class="hljs-comment">/* A cor de fundo foi removida daqui, pois o JS agora a controla */</span>
}
<span class="hljs-selector-id">#player-health-text</span> {
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">10px</span>;
  <span class="hljs-attribute">line-height</span>: <span class="hljs-number">14px</span>;
}

<span class="hljs-comment">/* Centralização do Indicador de Fase */</span>
<span class="hljs-selector-class">.hud-stats</span> {
  <span class="hljs-attribute">position</span>: absolute;
  <span class="hljs-attribute">left</span>: <span class="hljs-number">50%</span>;
  <span class="hljs-attribute">top</span>: <span class="hljs-number">50%</span>;
  <span class="hljs-attribute">transform</span>: <span class="hljs-built_in">translate</span>(-<span class="hljs-number">50%</span>, -<span class="hljs-number">50%</span>);
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">14px</span>; <span class="hljs-comment">/* Fonte menor */</span>
}
<span class="hljs-selector-class">.hud-stats</span> <span class="hljs-selector-tag">p</span> {
  <span class="hljs-attribute">margin</span>: <span class="hljs-number">0</span>;
}

<span class="hljs-comment">/* Botão de Pausa Menor */</span>
<span class="hljs-selector-id">#pause-button</span> {
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">9px</span>; <span class="hljs-comment">/* Bem pequeno */</span>
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">4px</span> <span class="hljs-number">8px</span>;
}

<span class="hljs-comment">/* Objetivo da Fase */</span>
<span class="hljs-selector-class">.hud-bottom</span> {
  <span class="hljs-attribute">text-align</span>: center;
  <span class="hljs-attribute">margin-top</span>: <span class="hljs-number">4px</span>;
}
<span class="hljs-selector-id">#objective-text</span> { 
