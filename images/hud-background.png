rl(#__lottie_element_2349)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;"><g><path stroke="url(#__lottie_element_2342)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div><!----><!----></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c3358885363="" class="response-container-content ng-tns-c3358885363-161 has-thoughts"><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c927349975="" class="response-content ng-tns-c3358885363-161"><!----><model-thoughts _ngcontent-ng-c927349975="" _nghost-ng-c1786796508="" class="ng-tns-c1786796508-164 ng-star-inserted" style="height: auto;"><div _ngcontent-ng-c1786796508="" class="model-thoughts ng-tns-c1786796508-164"><div _ngcontent-ng-c1786796508="" class="thoughts-header ng-tns-c1786796508-164"><button _ngcontent-ng-c1786796508="" mat-button="" data-test-id="thoughts-header-button" class="mdc-button mat-mdc-button-base thoughts-header-button ng-tns-c1786796508-164 mat-mdc-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="247951;track:generic_click,impression"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-content"><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-label ng-tns-c1786796508-164"><span _ngcontent-ng-c1786796508="" class="ng-tns-c1786796508-164">Mostrar raciocínio</span></div><div _ngcontent-ng-c1786796508="" class="thoughts-header-button-icons ng-tns-c1786796508-164"><!----><mat-icon _ngcontent-ng-c1786796508="" role="img" fonticon="expand_more" class="mat-icon notranslate thoughts-header-button-icon ng-tns-c1786796508-164 google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="expand_more"></mat-icon><!----></div></div></span><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button></div><!----></div></model-thoughts><!----><!----><!----><!----><message-content _ngcontent-ng-c927349975="" class="model-response-text ng-star-inserted has-thoughts" _nghost-ng-c3841436833="" id="message-content-id-r_fdf1933d5fd75d76" style="height: auto;"><div _ngcontent-ng-c3841436833="" class="markdown markdown-main-panel stronger enable-updated-hr-color" id="model-response-message-contentr_fdf1933d5fd75d76" dir="ltr" style="--animation-duration: 400ms; --fade-animation-function: linear;"><p data-sourcepos="1:1-1:154">Ótima ideia! Implementar um sprite que rotaciona e tem uma hitbox desacoplada do seu tamanho visual é um passo importante para deixar o jogo mais polido.</p><p data-sourcepos="3:1-3:46">Para isso, faremos três alterações principais:</p><ol data-sourcepos="5:1-8:0">
<li data-sourcepos="5:1-5:85"><strong>Configurar o novo sprite:</strong> Garantir que o jogo use o seu arquivo <code>bullet.png</code>.</li>
<li data-sourcepos="6:1-6:117"><strong>Modificar a classe <code>Projectile</code>:</strong> Adicionaremos a lógica para que o projétil se desenhe com a rotação correta.</li>
<li data-sourcepos="7:1-8:0"><strong>Ajustar a função <code>shoot</code> do <code>Player</code>:</strong> Definiremos o tamanho visual e o tamanho da hitbox de forma independente.</li>
</ol><hr data-sourcepos="9:1-9:5"><h3 data-sourcepos="11:1-11:44">Passo 1: Configurar o Sprite do Projétil</h3><p data-sourcepos="13:1-13:86">Primeiro, vamos garantir que o jogo carregue e utilize a sua nova imagem <code>bullet.png</code>.</p><ol data-sourcepos="15:1-18:0">
<li data-sourcepos="15:1-15:91">Coloque o arquivo <code>bullet.png</code> que você enviou dentro da pasta <code>images</code> do seu projeto.</li>
<li data-sourcepos="16:1-16:50">Abra o arquivo <code>ECOM00_jogo/src/js/config.js</code>.</li>
<li data-sourcepos="17:1-18:0">Encontre a linha do <code>projectile</code> dentro do objeto <code>assetSources</code> e aponte para o seu novo arquivo.</li>
</ol><p data-sourcepos="19:1-19:32"><strong>Em <code>config.js</code>, altere isto:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-169 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-169 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-169 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-169">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-169 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-169 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target