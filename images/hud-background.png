};
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="29:1-29:14"><strong>Para isto:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-170 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-170 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-170 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-170">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-170 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-170 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-170"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-170"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-170"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-170" data-sourcepos="31:1-37:2"><span class="hljs-keyword">export</span> <span class="hljs-keyword">const</span> assetSources = {
  <span class="hljs-comment">// ... outros assets</span>
  <span class="hljs-attr">projectile</span>: <span class="hljs-string">'./images/bullet.png'</span>, <span class="hljs-comment">// &lt;&lt;&lt; Altere para usar seu sprite local</span>
  <span class="hljs-comment">// ... outros assets</span>
};
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><hr data-sourcepos="39:1-39:5"><h3 data-sourcepos="41:1-41:60">Passo 2: Modificar a Classe <code>Projectile</code> para Rotacionar</h3><p data-sourcepos="43:1-43:129">Agora, vamos dar ao projétil a capacidade de se desenhar com a rotação correta e de ter tamanhos diferentes para visual e hitbox.</p><p data-sourcepos="45:1-45:119"><strong>No arquivo <code>ECOM00_jogo/src/js/entities.js</code>, substitua toda a classe <code>Projectile</code> atual por esta versão aprimorada:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-171 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-171 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-171 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-171">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-171 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-171 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-171"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-171"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-171"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-171" data-sourcepos="47:1-90:1"><span class="hljs-keyword">export</span> <span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">Projectile</span> <span class="hljs-keyword">extends</span> <span class="hljs-title">Character</span> </span>{
    <span class="hljs-function"><span class="hljs-title">constructor</span>(<span class="hljs-params">x, y, width, height, sprite, vx, vy, direction</span>)</span> {
        <span class="hljs-comment">// 'width' e 'height' agora são para a HITBOX</span>
        <span class="hljs-built_in">super</span>(x, y, width, height, <span class="hljs-number">0</span>, sprite); 
        <span class="hljs-built_in">this</span>.vx = vx;
        <span class="hljs-built_in">this</span>.vy = vy;
        <span class="hljs-built_in">this</span>.direction = direction; <span class="hljs-comment">// Armazena a direção para o desenho</span>
    }

    <span class="hljs-function"><span class="hljs-title">update</span>(<span class="hljs-params"></span>)</span> { 
        <span class="hljs-built_in">this</span>.x += <span class="hljs-built_in">this</span>.vx; 
        <span class="hljs-built_in">this</span>.y += <span class="hljs-built_in">this</span>.vy; 
    }

    <span class="hljs-comment">// Sobrescrevemos a função de desenho para adicionar a rotação</span>
    <span class="hljs-function"><span class="hljs-title">draw</span>(<span class="hljs-params">ctx</span>)</span> {
        <span class="hljs-keyword">if</span> (!<span class="hljs-built_in">this</span>.sprite || !<span class="hljs-built_in">this</span>.sprite.complete || <span class="hljs-built_in">this</span>.sprite.naturalWidth === <span class="hljs-number">0</span>) <span class="hljs-keyword">return</span>;

        <span class="hljs-comment">// Pega o centro do projétil para rotacionar em torno dele</span>
        <span class="hljs-keyword">const</span> centerX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width / <span class="hljs-number">2</span>;
        <span class="hljs-keyword">const</span> centerY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height / <span class="hljs-number">2</span>;
        
        ctx.save(); <span class="hljs-comment">// Salva o estado atual do canvas</span>
        ctx.translate(centerX, centerY); <span class="hljs-comment">// Move o ponto de origem do canvas para o centro do projétil</span>

        <span class="hljs-comment">// Define o ângulo de rotação com base na direção</span>
        <span class="hljs-keyword">let</span> angle = <span class="hljs-number">0</span>;
        <span class="hljs-keyword">switch</span> (<span class="hljs-built_in">this</span>.direction) {
            <span class="hljs-keyword">case</span> <span class="hljs-string">'up'</span>:    angle = -<span class="hljs-built_in">Math</span>.PI / <span class="hljs-number">2</span>; <span class="hljs-keyword">break</span>; <span class="hljs-comment">// -90 graus</span>
            <span class="hljs-keyword">case</span> <span class="hljs-string">'down'</span>:  angle = <span class="hljs-built_in">Math</span>.PI / <span class="hljs-number">2</span>;  <span class="hljs-keyword">break</span>; <span class="hljs-comment">// 90 graus</span>
            <span class="hljs-keyword">case</span> <span class="hljs-string">'left'</span>:  angle = <span class="hljs-built_in">Math</span>.PI;      <span class="hljs-keyword">break</span>; <span class="hljs-comment">// 180 graus</span>
            <span class="hljs-comment">// 'right' é 0, não precisa de case</span>
        }
        ctx.rotate(angle);

        <span class="hljs-comment">// Desenha a imagem no novo centro (0,0), usando seu tamanho real</span>
        <span class="hljs-comment">// O desenho é feito a partir de um ponto negativo para centralizar a imagem</span>
        ctx.drawImage(<span class="hljs-built_in">this</span>.sprite, -<span class="hljs-built_in">this</span>.sprite.width / <span class="hljs-number">2</span>, -<span class="hljs-built_in">this</span>.sprite.height / <span class="hljs-number">2</span>, <span class="hljs-built_in">this</span>.sprite.width, <span class="hljs-built_in">this</span>.sprite.height);

        ctx.restore(); <span class="hljs-comment">// Restaura o estado do canvas para o original</span>
    }
}
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><ul data-sourcepos="92:3-96:0">
<li data-sourcepos="92:3-96:0"><strong>O que mudou?</strong>
<ul data-sourcepos="93:7-96:0">
<li data-sourcepos="93:7-93:55">O construtor agora salva a <code>direction</code> do tiro.</li>
<li data-sourcepos="94:7-94:61">Criamos uma função <code>draw</code> específica para o projétil.</li>
<li data-sourcepos="95:7-96:0">Essa função usa <code>ctx.translate</code> e <code>ctx.rotate</code> para girar o sprite corretamente antes de desenhá-lo. A rotação é calculada com base na direção do tiro.</li>
</ul>
</li>
</ul><hr data-sourcepos="97:1-97:5"><h3 data-sourcepos="99:1-99:54">Passo 3: Ajustar a Função de Tiro (<code>Player.shoot</code>)</h3><p data-sourcepos="101:1-101:128">Finalmente, vamos modificar a função <code>shoot</code> para definir os tamanhos (visual e hitbox) e passar a direção para o novo projétil.</p><p data-sourcepos="103:1-103:119"><strong>Ainda no arquivo <code>ECOM00_jogo/src/js/entities.js</code>, substitua toda a sua função <code>shoot</code> na classe <code>Player</code> por esta:</strong></p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-172 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-172 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-172 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-172">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-172 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-172 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_fdf1933d5fd75d76&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_ddc977756bb77101&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-172"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-172"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-172"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-172" data-sourcepos="105:1-150:3">  <span class="hljs-function"><span class="hljs-title">shoot</span>(<span class="hljs-params">direction</span>)</span> {
    <span class="hljs-built_in">this</span>.direction = direction;
    <span class="hljs-keyword">let</span> projX, projY, vx = <span class="hljs-number">0</span>, vy = <span class="hljs-number">0</span>;
    <span class="hljs-keyword">const</span> projSpeed = <span class="hljs-number">8</span>;
    
    <span class="hljs-comment">// &lt;&lt;&lt; A MÁGICA ACONTECE AQUI &gt;&gt;&gt;</span>
    <span class="hljs-comment">// Defina o tamanho da hitbox (para colisões) e o tamanho visual (para desenho)</span>
    <span class="hljs-comment">// A hitbox é menor que o sprite para uma colisão mais justa.</span>
    <span class="hljs-keyword">const</span> hitboxWidth = <span class="hljs-number">22</span>;
    <span class="hljs-keyword">const</span> hitboxHeight = <span class="hljs-number">10</span>;

    <span class="hljs-comment">// Ajuste projX e projY para que o projétil saia do centro do jogador</span>
    <span class="hljs-keyword">switch</span> (direction) {
      <span class="hljs-keyword">case</span> <span class="hljs-string">"up"</span>: 
        projX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width / <span class="hljs-number">2</span> - hitboxWidth / <span class="hljs-number">2</span>; 
        projY = <span class="hljs-built_in">this</span>.y - hitboxHeight; 
        vy = -projSpeed; 
        <span class="hljs-keyword">break</span>;
      <span class="hljs-keyword">case</span> <span class="hljs-string">"down"</span>: 
        projX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width / <span class="hljs-number">2</span> - hitboxWidth / <span class="hljs-number">2</span>; 
        projY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height; 
        vy = projSpeed; 
        <span class="hljs-keyword">break</span>;
      <span class="hljs-keyword">case</span> <span class="hljs-string">"left"</span>: 
        projX = <span class="hljs-built_in">this</span>.x - hitboxWidth; 
        projY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height / <span class="hljs-number">2</span> - hitboxHeight / <span class="hljs-number">2</span>; 
        vx = -projSpeed; 
        <span class="hljs-keyword">break</span>;
      <span class="hljs-keyword">case</span> <span class="hljs-string">"right"</span>: 
        projX = <span class="hljs-built_in">this</span>.x + <span class="hljs-built_in">this</span>.width; 
        projY = <span class="hljs-built_in">this</span>.y + <span class="hljs-built_in">this</span>.height / <span class="hljs-number">2</span> - hitboxHeight / <span class="hljs-number">2</span>; 
        vx = projSpeed; 
        <span class="hljs-keyword">break</span>;
    }

    <span class="hljs-keyword">if</span> (vx !== <span class="hljs-number">0</span> || vy !== <span class="hljs-number">0</span>) {
      <span class="hljs-comment">// Cria o novo projétil, passando a hitbox e a direção</span>
      gameState.projectiles.push(
        <span class="hljs-keyword">new</span> Projectile(projX, projY, hitboxWidth, hitboxHeight, images.projectile, vx, vy, direction)
      );
      gameState.canShoot = <span class="hljs-literal">false</span>;
      <span class="hljs-built_in">setTimeout</span>(<span class="hljs-function">() =&gt;</span> { gameState.canShoot = <span class="hljs-literal">true</span>; }, gameState.shootCooldown);
    }
  }
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><ul data-sourcepos="152:3-157:0">
<li data-sourcepos="152:3-157:0"><strong>O que mudou?</strong>
<ul data-sourcepos="153:7-157:0">
<li data-sourcepos="153:7-153:47">Removemos a antiga variável <code>projSize</code>.</li>
<li data-sourcepos="154:7-154:194">Definimos <code>hitboxWidth</code> e <code>hitboxHeight</code>. <strong>Você pode ajustar esses valores</strong> para ter a colisão que desejar. Uma hitbox menor que o sprite geralmente parece mais "justa" para o jogador.</li>
<li data-sourcepos="155:7-155:103">A função <code>new Projectile</code> agora recebe a <code>hitboxWidth</code>, <code>hitboxHeight</code> e a <code>direction</code> do tiro.</li>
<li data-sourcepos="156:7-157:0">O tamanho visual será o tamanho real do arquivo <code>bullet.png</code>, que é lido e usado na nova função <code>Projectile.draw</code>.</li>
</ul>
</li>
</ul><p data-sourcepos="158:1-158:176">Após fazer essas alterações, seu projétil irá rotacionar de acordo com a direção do disparo e terá uma hitbox que você pode ajustar de forma independente do seu tamanho visual.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted"><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-161"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-173 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-173"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-173 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-173 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="Boa resposta" aria-label="Boa resposta" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger icon-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-pressed="false" aria-controls="feedback-form-5" jslog="173913;track:generic_click,impression