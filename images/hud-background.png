ialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_76cc3cf69f3d4d80&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_84c897a79e822cae&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-466"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-466"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-466"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-466" data-sourcepos="76:1-88:24"><span class="hljs-comment">// Dentro da função drawHUD em ui.js</span>

<span class="hljs-comment">// ... (atualização do texto da vida) ...</span>

<span class="hljs-comment">// Atualiza outros textos da HUD</span>
<span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"phase-text"</span>).textContent = gameState.phase + <span class="hljs-number">1</span>;
<span class="hljs-comment">// APAGUE A LINHA ABAIXO</span>
<span class="hljs-built_in">document</span>.getElementById(<span class="hljs-string">"score-text"</span>).textContent = gameState.score;

<span class="hljs-keyword">const</span> config = phaseConfigs[gameState.phase];
<span class="hljs-comment">// ... (resto da função)</span>
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-sourcepos="90:1-90:42">Passo 3: Embelezar a Interface com CSS</h3><p data-sourcepos="92:1-92:89">Esta é a parte principal. Vamos refazer o estilo do HUD e criar o novo estilo dos botões.</p><p data-sourcepos="94:1-94:46"><strong>No arquivo <code>ECOM00_jogo/src/css/main.css</code>:</strong></p><p data-sourcepos="96:1-96:169"><strong>Substitua o conteúdo inteiro</strong> deste arquivo pelo código abaixo. Ele contém um novo design para o HUD e para os botões, com um estilo pixel art mais coeso e agradável.</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-467 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-467 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_76cc3cf69f3d4d80&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_84c897a79e822cae&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-467 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-467">CSS</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-467 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-467 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_76cc3cf69f3d4d80&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_84c897a79e822cae&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-467"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-467"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-467"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-467" data-sourcepos="98:1-250:26"><span class="hljs-comment">/* Estilos Globais e de Layout */</span>
<span class="hljs-selector-tag">body</span> {
  <span class="hljs-attribute">margin</span>: <span class="hljs-number">0</span>;
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">0</span>;
  <span class="hljs-attribute">height</span>: <span class="hljs-number">100vh</span>;
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#0d0d0d</span>;
  <span class="hljs-attribute">font-family</span>: <span class="hljs-string">"VT323"</span>, monospace;
  <span class="hljs-attribute">display</span>: flex;
  <span class="hljs-attribute">justify-content</span>: center;
  <span class="hljs-attribute">align-items</span>: center;
}

<span class="hljs-selector-id">#game-wrapper</span> {
  <span class="hljs-attribute">position</span>: relative;
  <span class="hljs-attribute">width</span>: <span class="hljs-number">600px</span>;
  <span class="hljs-attribute">height</span>: <span class="hljs-number">600px</span>;
  <span class="hljs-attribute">background</span>: <span class="hljs-number">#222</span>;
  <span class="hljs-attribute">border</span>: <span class="hljs-number">4px</span> solid <span class="hljs-number">#4a4a4a</span>;
  <span class="hljs-attribute">box-shadow</span>: <span class="hljs-number">0</span> <span class="hljs-number">0</span> <span class="hljs-number">25px</span> <span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.5</span>);
  <span class="hljs-attribute">overflow</span>: hidden;
}

<span class="hljs-selector-class">.hidden</span> {
  <span class="hljs-attribute">display</span>: none <span class="hljs-meta">!important</span>;
}

<span class="hljs-comment">/* === NOVO ESTILO DO HUD === */</span>
<span class="hljs-selector-id">#hud</span> {
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">8px</span> <span class="hljs-number">12px</span>;
  <span class="hljs-attribute">background-color</span>: <span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.5</span>); <span class="hljs-comment">/* Fundo semitransparente */</span>
  <span class="hljs-attribute">border-bottom</span>: <span class="hljs-number">3px</span> solid <span class="hljs-number">#333</span>;
  <span class="hljs-attribute">border-image</span>: <span class="hljs-built_in">linear-gradient</span>(to right, <span class="hljs-number">#6a6a6a</span>, <span class="hljs-number">#2a2a2a</span>) <span class="hljs-number">1</span>;
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#fff</span>;
  <span class="hljs-attribute">text-shadow</span>: <span class="hljs-number">2px</span> <span class="hljs-number">2px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#000</span>;
}
<span class="hljs-selector-class">.hud-top</span> { 
  <span class="hljs-attribute">display</span>: flex; 
  <span class="hljs-attribute">justify-content</span>: space-between; 
  <span class="hljs-attribute">align-items</span>: center;
  gap: <span class="hljs-number">20px</span>;
}
<span class="hljs-selector-class">.hud-stats</span> {
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">20px</span>;
  <span class="hljs-attribute">font-weight</span>: bold;
}
<span class="hljs-selector-id">#objective-text</span> { 
  <span class="hljs-attribute">margin-top</span>: <span class="hljs-number">8px</span>;
  <span class="hljs-attribute">text-align</span>: center;
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#ffc107</span>; 
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">18px</span>; 
}

<span class="hljs-comment">/* === NOVO ESTILO DOS BOTÕES === */</span>
<span class="hljs-selector-class">.pixel-button</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#5f5f5f</span>;
  <span class="hljs-attribute">color</span>: white;
  <span class="hljs-attribute">font-family</span>: <span class="hljs-string">"Press Start 2P"</span>, cursive;
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">14px</span>;
  <span class="hljs-attribute">text-shadow</span>: <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#000</span>;
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">12px</span> <span class="hljs-number">24px</span>;
  <span class="hljs-attribute">border</span>: <span class="hljs-number">2px</span> solid <span class="hljs-number">#222</span>;
  <span class="hljs-attribute">box-shadow</span>: inset -<span class="hljs-number">2px</span> -<span class="hljs-number">3px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#3c3c3c</span>, inset <span class="hljs-number">2px</span> <span class="hljs-number">3px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#a2a2a2</span>;
  <span class="hljs-attribute">cursor</span>: pointer;
  <span class="hljs-attribute">transition</span>: background-color <span class="hljs-number">0.1s</span>;
}

<span class="hljs-selector-class">.pixel-button</span><span class="hljs-selector-pseudo">:hover</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#6f6f6f</span>;
}

<span class="hljs-selector-class">.pixel-button</span><span class="hljs-selector-pseudo">:active</span> {
  <span class="hljs-attribute">position</span>: relative;
  <span class="hljs-attribute">top</span>: <span class="hljs-number">2px</span>;
  <span class="hljs-attribute">left</span>: <span class="hljs-number">2px</span>;
  <span class="hljs-attribute">box-shadow</span>: inset <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#3c3c3c</span>;
}

<span class="hljs-comment">/* Modificadores de cor para os botões */</span>
<span class="hljs-selector-class">.pixel-button--confirm</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#28a745</span>;
  <span class="hljs-attribute">box-shadow</span>: inset -<span class="hljs-number">2px</span> -<span class="hljs-number">3px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#1a6e2e</span>, inset <span class="hljs-number">2px</span> <span class="hljs-number">3px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#4cd26b</span>;
}
<span class="hljs-selector-class">.pixel-button--confirm</span><span class="hljs-selector-pseudo">:hover</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#32c052</span>;
}

<span class="hljs-selector-class">.pixel-button--danger</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#dc3545</span>;
  <span class="hljs-attribute">box-shadow</span>: inset -<span class="hljs-number">2px</span> -<span class="hljs-number">3px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#8b222c</span>, inset <span class="hljs-number">2px</span> <span class="hljs-number">3px</span> <span class="hljs-number">0px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#f35866</span>;
}
<span class="hljs-selector-class">.pixel-button--danger</span><span class="hljs-selector-pseudo">:hover</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#e44d5a</span>;
}

<span class="hljs-selector-id">#pause-button</span> {
  <span class="hljs-attribute">font-size</span>: <span class="hljs-number">12px</span>;
  <span class="hljs-attribute">padding</span>: <span class="hljs-number">8px</span> <span class="hljs-number">12px</span>;
}


<span class="hljs-comment">/* Outros Estilos (Menus, Barras de Vida, etc.) */</span>
<span class="hljs-selector-id">#start-menu</span>, <span class="hljs-selector-id">#pause-menu</span>, <span class="hljs-selector-id">#message-screen</span> {
  <span class="hljs-attribute">position</span>: absolute;
  <span class="hljs-attribute">top</span>: <span class="hljs-number">0</span>; <span class="hljs-attribute">left</span>: <span class="hljs-number">0</span>; <span class="hljs-attribute">width</span>: <span class="hljs-number">100%</span>; <span class="hljs-attribute">height</span>: <span class="hljs-number">100%</span>;
  <span class="hljs-attribute">display</span>: flex;
  <span class="hljs-attribute">flex-direction</span>: column;
  <span class="hljs-attribute">justify-content</span>: center;
  <span class="hljs-attribute">align-items</span>: center;
  <span class="hljs-attribute">text-align</span>: center;
  <span class="hljs-attribute">font-family</span>: <span class="hljs-string">"Press Start 2P"</span>, cursive;
  <span class="hljs-attribute">z-index</span>: <span class="hljs-number">100</span>;
  <span class="hljs-attribute">color</span>: <span class="hljs-number">#fff</span>;
  gap: <span class="hljs-number">20px</span>;
}

<span class="hljs-selector-id">#start-menu</span> {
  <span class="hljs-attribute">background-image</span>: <span class="hljs-built_in">linear-gradient</span>(<span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.6</span>), <span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.6</span>)), <span class="hljs-built_in">url</span>(<span class="hljs-string">'../../images/menu-background.png'</span>);
  <span class="hljs-attribute">background-size</span>: cover;
  <span class="hljs-attribute">background-position</span>: center;
}
<span class="hljs-selector-id">#pause-menu</span>, <span class="hljs-selector-id">#message-screen</span> {
  <span class="hljs-attribute">background-color</span>: <span class="hljs-built_in">rgba</span>(<span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0</span>, <span class="hljs-number">0.85</span>);
}

<span class="hljs-selector-id">#game-title</span>, <span class="hljs-selector-id">#pause-title</span>, <span class="hljs-selector-id">#message-title</span> { <span class="hljs-attribute">font-size</span>: <span class="hljs-number">32px</span>; <span class="hljs-attribute">color</span>: <span class="hljs-number">#ffc107</span>; <span class="hljs-attribute">text-shadow</span>: <span class="hljs-number">3px</span> <span class="hljs-number">3px</span> <span class="hljs-number">0</span> <span class="hljs-number">#000</span>; <span class="hljs-attribute">margin</span>: <span class="hljs-number">0</span>;}
<span class="hljs-selector-id">#game-subtitle</span>, <span class="hljs-selector-id">#message-subtitle</span> { <span class="hljs-attribute">font-size</span>: <span class="hljs-number">16px</span>; <span class="hljs-attribute">color</span>: <span class="hljs-number">#f0f0f0</span>; <span class="hljs-attribute">max-width</span>: <span class="hljs-number">80%</span>; <span class="hljs-attribute">line-height</span>: <span class="hljs-number">1.5</span>; <span class="hljs-attribute">margin</span>: <span class="hljs-number">0</span>;}


<span class="hljs-comment">/* Barras de Vida */</span>
<span class="hljs-selector-id">#player-health-container</span> {
  <span class="hljs-attribute">position</span>: relative; <span class="hljs-attribute">width</span>: <span class="hljs-number">180px</span>; <span class="hljs-attribute">height</span>: <span class="hljs-number">22px</span>;
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#333</span>;
  <span class="hljs-attribute">border</span>: <span class="hljs-number">2px</span> solid <span class="hljs-number">#222</span>;
  <span class="hljs-attribute">box-shadow</span>: inset <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#000</span>, inset -<span class="hljs-number">1px</span> -<span class="hljs-number">1px</span> <span class="hljs-number">0px</span> <span class="hljs-number">#000</span>;
}
<span class="hljs-selector-id">#player-health-bar</span> {
  <span class="hljs-attribute">height</span>: <span class="hljs-number">100%</span>;
  <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#28a745</span>;
  <span class="hljs-attribute">transition</span>: width <span class="hljs-number">0.3s</span> ease-in-out;
}
<span class="hljs-selector-id">#player-health-text</span> {
  <span class="hljs-attribute">position</span>: absolute; <span class="hljs-attribute">width</span>: <span class="hljs-number">100%</span>; <span class="hljs-attribute">text-align</span>: center;
  <span class="hljs-attribute">color</span>: white; <span class="hljs-attribute">font-size</span>: <span class="hljs-number">14px</span>; <span class="hljs-attribute">font-weight</span>: bold;
  <span class="hljs-attribute">text-shadow</span>: <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> <span class="hljs-number">1px</span> black;
}

<span class="hljs-selector-id">#boss-health-container</span> { <span class="hljs-attribute">position</span>: absolute; <span class="hljs-attribute">bottom</span>: <span class="hljs-number">20px</span>; <span class="hljs-attribute">left</span>: <span class="hljs-number">10%</span>; <span class="hljs-attribute">width</span>: <span class="hljs-number">80%</span>; <span class="hljs-attribute">height</span>: <span class="hljs-number">25px</span>; <span class="hljs-attribute">z-index</span>: <span class="hljs-number">5</span>; <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#555</span>; <span class="hljs-attribute">border</span>: <span class="hljs-number">3px</span> solid <span class="hljs-number">#222</span>; <span class="hljs-attribute">border-radius</span>: <span class="hljs-number">8px</span>; }
<span class="hljs-selector-id">#boss-health-bar</span> { <span class="hljs-attribute">background-color</span>: <span class="hljs-number">#e74c3c</span>; <span class="hljs-attribute">height</span>: <span class="hljs-number">100%</span>; }

<span class="hljs-comment">/* Canvas */</span>
<span class="hljs-selector-tag">canvas</span> { <span class="hljs-attribute">display</span>: block; }
</code></pre><!----><!----><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-sourcepos="252:1-252:150">Após aplicar todas essas mudanças, seu jogo terá uma interface muito mais limpa e com uma identidade visual de "pixel art" bem mais forte e agradável.</p></div></message-content><!----><!----><div _ngcontent-ng-c927349975="" class="response-footer gap has-thoughts complete"><!----><!----><!----><sources-list _ngcontent-ng-c927349975="" class="sources-list ng-star-inserted"><overview-carousel _nghost-ng-c3831108472="" class="ng-star-inserted"><!----><sources-sidebar-button _ngcontent-ng-c3831108472="" _nghost-ng-c1702140789="" class="ng-star-inserted"><!----></sources-sidebar-button><!----><!----><!----></overview-carousel><!----></sources-list><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c927349975="" _nghost-ng-c3572881400="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c3358885363="" class="response-container-footer ng-tns-c3358885363-459"><message-actions _ngcontent-ng-c927349975="" footer="" _nghost-ng-c1790889713="" class="ng-tns-c1790889713-468 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c1790889713="" class="actions-container-v2 ng-tns-c1790889713-468"><div _ngcontent-ng-c1790889713="" class="buttons-container-v2 ng-tns-c1790889713-468 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c1790889713="" _nghost-ng-c1126443278="" class="ng-tns-c1790889713-468 ng-star-inserted"><button _ngcontent-ng-c1126443278="" mat-icon-button="" mattooltip="Boa resposta" aria-label="Boa resposta" cl