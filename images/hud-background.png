<response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c1224449439="" class="ng-tns-c1224449439-355 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c1224449439="" class="code-block ng-tns-c1224449439-355 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression;BardVeMetadataKey:[[&quot;r_25fb2254addf5d99&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_f2cdbb19d5084403&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]]" style="display: block;"><div _ngcontent-ng-c1224449439="" class="code-block-decoration header-formatted gds-title-s ng-tns-c1224449439-355 ng-star-inserted" style=""><span _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-355">JavaScript</span><div _ngcontent-ng-c1224449439="" class="buttons ng-tns-c1224449439-355 ng-star-inserted"><button _ngcontent-ng-c1224449439="" aria-label="Copiar o código" mat-icon-button="" mattooltip="Copiar o código" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c1224449439-355 mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_25fb2254addf5d99&quot;,&quot;c_a99c9efdec04d64a&quot;,null,&quot;rc_f2cdbb19d5084403&quot;,null,null,&quot;pt&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c1224449439="" role="img" fonticon="content_copy" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><!----><!----></div><!----></div><!----><div _ngcontent-ng-c1224449439="" class="formatted-code-block-internal-container ng-tns-c1224449439-355"><div _ngcontent-ng-c1224449439="" class="animated-opacity ng-tns-c1224449439-355"><pre _ngcontent-ng-c1224449439="" class="ng-tns-c1224449439-355"><code _ngcontent-ng-c1224449439="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1224449439-355" data-sourcepos="41:9-43:54"><span class="hljs-keyword">const</span> story = narrativeTexts[gameState.phase];
